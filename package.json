{
  "name": "club-pool-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test:limitless": "mocha -r ts-node/register 'test/limitless/**/*.test.ts'",
    "start": "node dist/index.js",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:check-balance": "ts-node scripts/checkDeployerBalance.ts",
    "contracts:diagnose:polygon": "ts-node scripts/diagnosePolygon.ts",
    "contracts:deploy:polygon": "hardhat run scripts/deployPolygon.ts --network polygon",
    "contracts:transfer-ownership:polygon": "hardhat run scripts/transferFactoryOwnership.ts --network polygon",
    "contracts:deploy:base": "hardhat run scripts/deployBase.ts --network base",
    "contracts:deploy:chiliz": "hardhat run scripts/deployChiliz.ts --network chiliz",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@polymarket/builder-relayer-client": "^0.0.9",
    "@polymarket/builder-signing-sdk": "^1.0.0",
    "@polymarket/clob-client-v2": "^1.0.6",
    "@prisma/client": "^5.19.1",
    "bullmq": "^5.19.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.14.0",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "pino": "^9.3.2",
    "socket.io-client": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "viem": "^2.50.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@openzeppelin/contracts": "5.0.2",
    "@openzeppelin/contracts-upgradeable": "^5.0.2",
    "@types/chai": "^4.3.20",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.14.12",
    "@types/swagger-ui-express": "^4.1.8",
    "chai": "^4.5.0",
    "hardhat": "^2.22.19",
    "prisma": "^5.19.1",
    "ts-node": "^10.9.2",
    "tsc-watch": "^6.0.4",
    "typescript": "^5.5.4"
  }
}
