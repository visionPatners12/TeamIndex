generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PoolStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum PositionStatus {
  OPEN
  SETTLED
  CANCELLED
}

enum QueueStatus {
  SCHEDULED
  PROCESSING
  EXECUTED
  SKIPPED
  FAILED
  CANCELLED
}

enum CrossChainDepositStatus {
  RECEIVED        // Source-chain funds landed on receiver contract
  BRIDGING        // Funds being bridged/swapped to Polygon USDC
  DEPOSITING      // USDC being deposited into Polygon vault
  MINTING_SHARES  // Wrapped shares being minted on source chain
  COMPLETED       // Done — user has wrapped shares
  FAILED          // Permanent failure
  NEEDS_MANUAL_RECONCILIATION // A tx may have landed without a persisted hash
}

enum CrossChainRedemptionStatus {
  BURN_REQUESTED  // User wants to burn wrapped shares
  BURNED          // Shares burned on Chiliz
  WITHDRAWING     // USDC being withdrawn from Polygon vault
  SETTLING        // Value being sent back to user on Chiliz
  COMPLETED
  FAILED
}

enum Side {
  YES
  NO
}

model club_pools {
  id                     String   @id @default(cuid())
  clubName               String
  symbol                 String
  // Canonical sports_data.teams.id used to discover Limitless markets by home_id/away_id.
  sportsDataTeamId       String?  @db.Uuid
  // Legacy Polymarket mapping kept only for old rows.
  polymarketTeamId       String?
  // If using `ClubVaultFactory`, this is the deployed per-club vault address.
  // Used so `tx/deposit` and admin vault calls always target the same vault.
  vaultAddress          String?
  depositCap             Decimal  @db.Decimal(78, 18) @default(0)
  cash                   Decimal  @db.Decimal(78, 18) @default(0)
  openPositionsValue    Decimal  @db.Decimal(78, 18) @default(0)
  realizedPnl            Decimal  @db.Decimal(78, 18) @default(0)
  totalPoolValue         Decimal  @db.Decimal(78, 18) @default(0)
  totalTokenSupply       Decimal  @db.Decimal(78, 18) @default(0)
  officialTokenPrice     Decimal  @db.Decimal(78, 18) @default(0)
  riskParams             Json     @default("{}")
  status                 PoolStatus @default(ACTIVE)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  users                club_pool_users[]
  transactions         club_pool_transactions[]
  positions            club_pool_positions[]
  snapshots            club_pool_price_snapshots[]
  candidates           club_market_candidates[]
  matchQueue           club_match_queue[]
  selectedMarkets      pool_selected_markets[]
  allocationProposals  pool_allocation_proposals[]

  @@index([sportsDataTeamId])
}

// Admin-selected Polymarket markets for a pool (used by allocation engine)
model pool_selected_markets {
  id              String   @id @default(cuid())
  poolId          String
  marketId        String
  conditionId     String
  tokenId         String
  eventId         String   @default("")
  question        String
  marketType      String   @default("game")   // "game" | "future"
  selectedSide    Side     @default(YES)
  manualClusterId String?
  endDateIso      String?
  liquidity       Decimal  @db.Decimal(78, 18) @default(0)
  yesPrice        Decimal  @db.Decimal(78, 18) @default(0)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pool club_pools @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([poolId, conditionId])
  @@index([poolId])
}

// Accepted allocation proposals saved by admin
model pool_allocation_proposals {
  id               String   @id @default(cuid())
  poolId           String
  nav              Decimal  @db.Decimal(78, 18)
  targetExposure   Decimal  @db.Decimal(78, 18)
  cashWeight       Decimal  @db.Decimal(78, 18)
  cashAmount       Decimal  @db.Decimal(78, 18)
  portfolioQuality Decimal  @db.Decimal(78, 18) @default(0)
  proposalJson     Json
  selectedMarketsJson Json
  /// Snapshot of the CLOB/Gamma market data the engine consumed (keyed by conditionId).
  marketDataJson   Json?
  status           String   @default("ACCEPTED")
  createdAt        DateTime @default(now())

  pool club_pools @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId, createdAt])
}

model club_pool_users {
  id          String   @id @default(cuid())
  poolId      String
  userAddress String
  tokenBalance Decimal @db.Decimal(78, 18) @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pool club_pools @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([poolId, userAddress])
  @@index([userAddress])
}

model club_pool_transactions {
  id             String   @id @default(cuid())
  poolId         String
  /// On-chain tx hash (lowercase) for idempotent ingest after user deposit.
  txHash         String?
  userAddress    String
  depositAmount  Decimal  @db.Decimal(78, 18)
  netPoolAmount  Decimal  @db.Decimal(78, 18)
  feeAmount      Decimal  @db.Decimal(78, 18)
  tokenPriceAtMint Decimal @db.Decimal(78, 18)
  tokensMinted   Decimal  @db.Decimal(78, 18)
  createdAt      DateTime @default(now())

  pool club_pools @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([poolId, txHash])
  @@index([poolId, userAddress])
}

model club_pool_positions {
  id              String   @id @default(cuid())
  poolId          String
  queueId         String?  @unique
  eventId         String
  marketId        String
  tokenId         String
  clobOrderId    String?
  side            Side
  entryPrice      Decimal @db.Decimal(78, 18)
  // Planned execution (based on tranche sizing at creation time).
  plannedStake    Decimal @db.Decimal(78, 18) @default(0)
  plannedQuantity Decimal @db.Decimal(78, 18) @default(0)

  // Filled execution (updated by CLOB fill sync).
  stake           Decimal @db.Decimal(78, 18) @default(0)
  quantity        Decimal @db.Decimal(78, 18) @default(0)

  // Cash already deducted from pool.cash for invested stake.
  investedAmount  Decimal @db.Decimal(78, 18) @default(0)

  currentValue    Decimal @db.Decimal(78, 18) @default(0)
  realizedPnl     Decimal @db.Decimal(78, 18) @default(0)
  status          PositionStatus @default(OPEN)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pool club_pools @relation(fields: [poolId], references: [id], onDelete: Cascade)
  queue club_match_queue? @relation(fields: [queueId], references: [id], onDelete: SetNull)

  @@index([poolId, tokenId])
}

model club_pool_price_snapshots {
  id               String   @id @default(cuid())
  poolId           String
  cash             Decimal  @db.Decimal(78, 18)
  positionsValue   Decimal  @db.Decimal(78, 18)
  realizedPnl      Decimal  @db.Decimal(78, 18)
  totalPoolValue   Decimal  @db.Decimal(78, 18)
  officialTokenPrice Decimal @db.Decimal(78, 18)
  snapshotTime     DateTime @default(now())

  pool club_pools @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId, snapshotTime])
}

model club_teams_map {
  id             String @id @default(cuid())
  internalClubName String
  polymarketTeamId String
  createdAt      DateTime @default(now())

  @@unique([internalClubName, polymarketTeamId])
}

model club_market_candidates {
  id            String @id @default(cuid())
  poolId        String
  clubName      String
  eventId       String
  marketId      String
  tokenId       String
  side          Side
  kickoffTime   DateTime?
  entryWindow   DateTime?
  liquidityUsd  Decimal @db.Decimal(78, 18) @default(0)
  status        String @default("CANDIDATE")
  discoveredAt   DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pool club_pools @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId, eventId, tokenId])
}

model club_match_queue {
  id              String     @id @default(cuid())
  poolId          String
  candidateId    String
  executionTime  DateTime
  tranche         Int // 48h=1, 24h=2
  stakeUsd        Decimal  @db.Decimal(78, 18)
  status          QueueStatus @default(SCHEDULED)
  lockedAt        DateTime?
  lockedBy        String?
  attempts        Int       @default(0)
  executedAt      DateTime?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  pool club_pools @relation(fields: [poolId], references: [id], onDelete: Cascade)
  position club_pool_positions?

  @@index([poolId, executionTime, status])
  @@unique([poolId, candidateId, tranche])
}

// ============================
// Cross-chain (Chiliz <-> Polygon)
// ============================

model cross_chain_deposits {
  id                  String   @id @default(cuid())
  poolId              String
  userAddress         String   // user wallet on Chiliz
  sourceToken         String   // address(0) = native CHZ, else fan token address
  sourceAmount        Decimal  @db.Decimal(78, 18)
  chilizDepositId     BigInt   // on-chain depositId from ChilizDepositReceiver
  chilizTxHash        String?  // tx hash on Chiliz chain

  usdcAmount          Decimal? @db.Decimal(78, 18) // USDC received after bridge/swap
  polygonDepositTxHash String? // vault deposit tx on Polygon
  sharesMinted        Decimal? @db.Decimal(78, 18)
  chilizMintTxHash    String?  // wrapped share mint tx on Chiliz

  status              CrossChainDepositStatus @default(RECEIVED)
  processingLockedAt  DateTime?
  processingLockedBy  String?
  processingStep      String?
  attempts            Int      @default(0)
  lastError           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([poolId, userAddress])
  @@index([status])
  @@index([status, processingLockedAt])
  @@unique([chilizDepositId])
}

model base_chain_deposits {
  id                    String   @id @default(cuid())
  poolIdHash            String   // bytes32 hash emitted by BaseDepositReceiver
  clubPoolId            String?
  userAddress           String   // user wallet on Base
  sourceToken           String   // Base USDC address
  sourceAmount          Decimal  @db.Decimal(78, 18)
  baseDepositId         BigInt   // on-chain depositId from BaseDepositReceiver
  baseTxHash            String?  // user deposit tx hash on Base
  releaseTxHash         String?  // receiver release tx hash on Base
  lifiBridgeTxHash      String?  // LI.FI bridge tx hash on Base
  polygonBalanceBeforeBridge Decimal? @db.Decimal(78, 18)

  usdcAmount            Decimal? @db.Decimal(78, 18) // USDC received on Polygon
  polygonDepositTxHash  String?  // vault deposit tx on Polygon
  sharesMinted          Decimal? @db.Decimal(78, 18)
  baseMintTxHash        String?  // wrapped share mint tx on Base

  status                CrossChainDepositStatus @default(RECEIVED)
  processingLockedAt    DateTime?
  processingLockedBy    String?
  processingStep        String?
  attempts              Int      @default(0)
  lastError             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([poolIdHash, userAddress])
  @@index([clubPoolId])
  @@index([status])
  @@index([status, processingLockedAt])
  @@unique([baseDepositId])
}

model cross_chain_redemptions {
  id                  String   @id @default(cuid())
  poolId              String
  userAddress         String   // user wallet on Chiliz
  sharesBurned        Decimal  @db.Decimal(78, 18)
  chilizBurnTxHash    String?

  usdcWithdrawn       Decimal? @db.Decimal(78, 18)
  polygonWithdrawTxHash String?
  settlementToken     String?  // what user gets back (CHZ address or native)
  settlementAmount    Decimal? @db.Decimal(78, 18)
  chilizSettleTxHash  String?

  status              CrossChainRedemptionStatus @default(BURN_REQUESTED)
  lastError           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([poolId, userAddress])
  @@index([status])
}

model chain_event_cursors {
  key                String   @id
  chain              String
  contractAddress    String
  eventName          String
  lastProcessedBlock BigInt   @default(0)
  lockedAt           DateTime?
  lockedBy           String?
  cooldownUntil      DateTime?
  lastError          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([chain, contractAddress, eventName])
  @@index([lockedAt])
  @@index([cooldownUntil])
}

// ============================
// Global system settings (singleton row with key="default")
// ============================

model system_settings {
  key             String   @id @default("default")
  /// When false, the Chiliz deposit flow is hidden in the user-facing UI.
  /// The admin panel can still toggle it, and CHZ/USD price is always shown.
  chilizEnabled   Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

// ============================
// Limitless pipeline (migration from Polymarket)
// ============================

/// Singleton row tracking the Limitless sync state.
/// provider = 'polymarket' | 'limitless' — which data source is currently active.
model limitless_sync_state {
  id            String    @id @default("default")
  provider      String    @default("limitless")
  /// Pagination cursor returned by the last Limitless API page (market id or offset).
  cursor        String?
  lastSyncedAt  DateTime?
  marketsSynced Int       @default(0)
  /// IDLE | SYNCING | ERROR
  status        String    @default("IDLE")
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/// Market categories fetched from Limitless API — pipeline only, not queried client-side.
model limitless_categories {
  id        String    @id
  slug      String    @unique
  label     String
  rawJson   Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  markets   limitless_markets[]
}

/// Raw markets fetched from Limitless API — pipeline only, not queried client-side.
model limitless_markets {
  id          String    @id
  categoryId  String?
  title       String
  description String?
  /// ACTIVE | CLOSED | RESOLVED
  status      String    @default("ACTIVE")
  /// Winning outcome title when the market is resolved.
  resolution  String?
  /// Implied probability for outcome[0] (YES / first outcome).
  yesPrice    Decimal   @db.Decimal(10, 6) @default(0)
  /// Implied probability for outcome[1] (NO / second outcome).
  noPrice     Decimal   @db.Decimal(10, 6) @default(0)
  liquidity   Decimal   @db.Decimal(20, 6) @default(0)
  volume      Decimal   @db.Decimal(20, 6) @default(0)
  endDate     DateTime?
  rawJson     Json?
  syncedAt    DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category    limitless_categories? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  prices      limitless_prices[]
  game        lim_games?

  @@index([categoryId])
  @@index([status])
  @@index([endDate])
}

/// Historical price ticks per market outcome — pipeline only, not queried client-side.
model limitless_prices {
  id           BigInt   @id @default(autoincrement())
  marketId     String
  /// 0 = YES / first outcome, 1 = NO / second outcome.
  outcomeIndex Int      @default(0)
  price        Decimal  @db.Decimal(10, 6)
  /// Point-in-time when this price was observed.
  timestamp    DateTime
  createdAt    DateTime @default(now())

  market limitless_markets @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([marketId, outcomeIndex, timestamp])
  @@index([marketId, timestamp(sort: Desc)])
}

/// Sport/league/team enrichment for Limitless markets — populated by /sports pipeline.
/// One row per market identified as a sports fixture. Not queried client-side.
model lim_games {
  id        String    @id @default(cuid())
  marketId  String    @unique
  /// e.g. "soccer", "basketball", "tennis"
  sport     String?
  /// e.g. "Premier League", "NBA", "Champions League"
  league    String?
  /// Home team or first player name.
  homeTeam  String?
  /// Away team or second player name.
  awayTeam  String?
  /// Expected kick-off / start time of the fixture.
  gameTime  DateTime?
  rawJson   Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  market limitless_markets @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([sport, league])
  @@index([gameTime])
}
